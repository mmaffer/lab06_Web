<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post ? 'Editar Post' : 'Nuevo Post' %> - Social Media</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="grey lighten-4">

  <nav>
    <div class="nav-wrapper teal">
      <a href="/posts" class="brand-logo center">Social Media</a>
      <ul id="nav-mobile" class="left">
        <li><a href="/posts"><i class="material-icons">arrow_back</i></a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <div class="row">
      <div class="col s12 m8 offset-m2">
        <div class="card">
          <div class="card-content">
            <span class="card-title"><%= post ? 'Editar Post' : 'Crear Nuevo Post' %></span>
            
            <% if (locals.error) { %>
              <div class="card-panel red lighten-4 red-text text-darken-4">
                <%= error %>
              </div>
            <% } %>

            <form action="<%= post ? '/posts/edit/' + post._id : '/posts' %>" method="POST">
              <div class="input-field">
                <input type="text" id="title" name="title" value="<%= post ? post.title : '' %>" required minlength="5" maxlength="30">
                <label for="title" class="<%= post ? 'active' : '' %>">Título (5-30 caracteres)</label>
              </div>

              <div class="input-field">
                <textarea id="content" name="content" class="materialize-textarea" required minlength="10"><%= post ? post.content : '' %></textarea>
                <label for="content" class="<%= post ? 'active' : '' %>">Contenido (Mínimo 10 caracteres)</label>
              </div>

              <div class="input-field">
                <input type="text" id="imageUrl" name="imageUrl" value="<%= post ? post.imageUrl : '' %>">
                <label for="imageUrl" class="<%= post ? 'active' : '' %>">URL de Imagen</label>
              </div>

              <div class="input-field">
                <input type="text" id="hashtags" name="hashtags" value="<%= post && post.hashtags ? post.hashtags.join(', ') : '' %>">
                <label for="hashtags" class="<%= post ? 'active' : '' %>">Hashtags (separados por comas)</label>
              </div>

              <div class="input-field">
                <select name="userId" required>
                  <option value="" disabled <%= !post ? 'selected' : '' %>>Elige un autor</option>
                  <% users.forEach(user => { %>
                    <option value="<%= user._id %>" <%= (post && post.user && post.user._id.toString() === user._id.toString()) ? 'selected' : '' %>>
                      <%= user.name %> <%= user.lastName %>
                    </option>
                  <% }) %>
                </select>
                <label>Autor</label>
              </div>

              <div class="center-align" style="margin-top: 20px;">
                <button type="submit" class="btn waves-effect waves-light teal">
                  <%= post ? 'Actualizar' : 'Publicar' %>
                  <i class="material-icons right">send</i>
                </button>
                <a href="/posts" class="btn-flat waves-effect">Cancelar</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var elems = document.querySelectorAll('select');
      M.FormSelect.init(elems);
      M.updateTextFields();
    });
  </script>
</body>
</html>
